{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "target": "es2025",
        "module": "esnext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "allowJs": true,
        "isolatedModules": true,
        "noEmit": true,
        "types": ["node", "vitest/globals"],
        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}